---
import LiquidGlass from "liquid-glass-astro";
import "../styles/globals.css";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=fallback" rel="stylesheet" />
  <title>Liquid Glass Astro</title>
  <style is:global>
    body { margin: 0; font-family: 'Geist', system-ui, -apple-system, sans-serif; -webkit-font-smoothing: antialiased; }
    @media (max-width: 768px) {
      .lg-glass { --lg-backdrop: blur(12px) saturate(160%) !important; }
    }
    #user-glass, #logout-glass {
      position: fixed;
      left: var(--lg-panel-x, 50%);
    }
  </style>
</head>
<body>
  <div class="grid grid-cols-1 grid-rows-2 md:grid-rows-1 md:grid-cols-3 shadow-2xl w-full max-w-5xl mx-auto md:my-10 h-screen md:max-h-[calc(100vh-5rem)] md:rounded-3xl overflow-hidden">
    <!-- Left Panel - Glass Effect Demo -->
    <div class="flex-1 relative overflow-auto min-h-screen md:col-span-2" id="scroll-container">
      <div class="w-full min-h-[200vh] absolute top-0 left-0 pb-96 mb-96">
        <img src="https://picsum.photos/2000/2000" class="w-full h-96 object-cover" alt="" fetchpriority="high" />
        <div class="flex flex-col gap-2" id="bright-section">
          <h2 class="text-2xl font-semibold my-5 text-center">Some Heading</h2>
          <p class="px-10">
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger<br />
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger<br />
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger<br />
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger<br />
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger<br />
            Bacon ipsum dolor amet hamburger Bacon ipsum dolor amet hamburger
          </p>
        </div>
        <img src="https://picsum.photos/1200/1200" class="w-full h-80 object-cover my-10" alt="" loading="lazy" />
        <img src="https://picsum.photos/1400/1300" class="w-full h-72 object-cover my-10" alt="" loading="lazy" />
        <img src="https://picsum.photos/1100/1200" class="w-full h-96 object-cover my-10 mb-96" alt="" loading="lazy" />
      </div>

      <div id="glass-user" data-glass-panel="user">
        <LiquidGlass
          id="user-glass"
          displacementScale={100}
          blurAmount={0.5}
          saturation={140}
          aberrationIntensity={2}
          elasticity={0}
          cornerRadius={32}
          overLight={false}
          mode="standard"
          style="top: 25%;"
        >
          <div class="w-72 max-w-[calc(100vw-2rem)]">
            <h3 class="text-xl font-semibold mb-4">User Info</h3>
            <div class="space-y-3">
              <div class="flex items-center space-x-3">
                <div class="w-12 h-12 bg-black/10 backdrop-blur rounded-full flex items-center justify-center text-white font-semibold">AW</div>
                <div>
                  <p class="font-medium">秋知</p>
                  <p class="text-sm text-white">AI工程爱好者</p>
                </div>
              </div>
              <div class="pt-2 space-y-2">
                <div class="flex justify-between">
                  <span class="text-sm text-white">Email:</span>
                  <span class="text-sm">praxiswalker@gmail.com</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sm text-white">Location:</span>
                  <span class="text-sm">China</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sm text-white">Joined:</span>
                  <span class="text-sm">2025.8.30</span>
                </div>
              </div>
            </div>
          </div>
        </LiquidGlass>
      </div>

      <div id="glass-logout" data-glass-panel="logout" hidden>
        <LiquidGlass
          id="logout-glass"
          displacementScale={64}
          blurAmount={0.1}
          saturation={130}
          aberrationIntensity={2}
          elasticity={0.35}
          cornerRadius={100}
          overLight={false}
          mode="standard"
          padding="8px 16px"
          clickable={true}
          style="top: 25%;"
        >
          <span class="text-lg font-medium flex items-center gap-2">
            Log Out
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M10 17l5-5-5-5v3H3v4h7v3z" />
              <path d="M19 3h-8a2 2 0 0 0-2 2v3h2V5h8v14h-8v-3H9v3a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z" />
            </svg>
          </span>
        </LiquidGlass>
      </div>
    </div>

    <!-- Right Panel - Control Panel -->
    <div class="row-start-2 rounded-t-3xl md:rounded-none md:col-start-3 bg-gray-900/80 min-h-[50vh] md:min-h-0 md:h-full overflow-y-auto backdrop-blur-md border-l border-white/10 p-6 md:p-8 flex flex-col">
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-white">Glassy Boi but Web</h2>
          <a href="https://github.com/AdgaiWalker/liquid-glass-Astro" target="_blank" rel="noreferrer" class="text-white/70 hover:text-white transition-colors p-2 hover:bg-white/10 rounded-lg" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.74.08-.74 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.46 11.46 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z" />
            </svg>
          </a>
        </div>
        <p class="text-white/60 text-sm">Liquid Glass container effect for Astro. With settings and effects and stuff.</p>
        <p class="font-semibold text-yellow-300 text-xs mt-2 leading-snug">This does not fully work in Safari and Firefox. Edge refraction needs Chromium-level SVG filter support.</p>
      </div>

      <!-- Tab Switcher -->
      <div class="flex mb-6 bg-white/5 rounded-lg p-1">
        <button class="tab-button flex-1 px-4 py-2 text-sm font-medium rounded-md bg-blue-500 text-white shadow-lg" data-tab="user" type="button">User Info Card</button>
        <button class="tab-button flex-1 px-4 py-2 text-sm font-medium rounded-md text-white/70 hover:text-white hover:bg-white/10" data-tab="logout" type="button">Log Out Button</button>
      </div>

      <!-- User Info Controls -->
      <form class="space-y-8 flex-1" data-controls="user">
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Refraction Mode</span>
          <div class="space-y-2">
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="standard" checked class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Standard</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="polar" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Polar</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="prominent" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Prominent</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="shader" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Shader (Experimental)</span></label>
          </div>
          <p class="text-xs text-white/50 mt-2">Controls the refraction calculation method</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Displacement Scale</span>
          <div class="mb-2"><span class="text-xl font-mono text-blue-300 output" data-output="displacementScale">100</span></div>
          <input type="range" min="0" max="200" step="1" value="100" name="displacementScale" />
          <p class="text-xs text-white/50 mt-2">Controls the intensity of edge distortion</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Blur Amount</span>
          <div class="mb-2"><span class="text-xl font-mono text-green-300 output" data-output="blurAmount">0.5</span></div>
          <input type="range" min="0" max="1" step="0.01" value="0.5" name="blurAmount" />
          <p class="text-xs text-white/50 mt-2">Controls backdrop blur intensity</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Saturation</span>
          <div class="mb-2"><span class="text-xl font-mono text-purple-300 output" data-output="saturation">140%</span></div>
          <input type="range" min="100" max="300" step="10" value="140" name="saturation" />
          <p class="text-xs text-white/50 mt-2">Controls color saturation of the backdrop</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Chromatic Aberration</span>
          <div class="mb-2"><span class="text-xl font-mono text-cyan-300 output" data-output="aberrationIntensity">2</span></div>
          <input type="range" min="0" max="20" step="1" value="2" name="aberrationIntensity" />
          <p class="text-xs text-white/50 mt-2">Controls RGB channel separation intensity</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Elasticity</span>
          <div class="mb-2"><span class="text-xl font-mono text-orange-300 output" data-output="elasticity">0.00</span></div>
          <input type="range" min="0" max="1" step="0.05" value="0" name="elasticity" />
          <p class="text-xs text-white/50 mt-2">Controls how much the glass reaches toward the cursor</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Corner Radius</span>
          <div class="mb-2"><span class="text-xl font-mono text-pink-300 output" data-output="cornerRadius">32px</span></div>
          <input type="range" min="0" max="100" step="1" value="32" name="cornerRadius" />
          <p class="text-xs text-white/50 mt-2">Controls the roundness of the glass corners</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Over Light</span>
          <label class="flex items-center space-x-3">
            <input type="checkbox" name="overLight" class="w-5 h-5 accent-blue-500" />
            <span class="text-sm text-white/90">Tint liquid glass dark</span>
          </label>
          <p class="text-xs text-white/50 mt-2">Makes the glass darker for better visibility on light backgrounds</p>
        </div>
      </form>

      <!-- Logout Controls -->
      <form class="space-y-8 flex-1" data-controls="logout" hidden>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Refraction Mode</span>
          <div class="space-y-2">
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="standard" checked class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Standard</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="polar" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Polar</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="prominent" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Prominent</span></label>
            <label class="flex items-center space-x-3 py-1"><input type="radio" name="mode" value="shader" class="w-5 h-5 accent-blue-500" /><span class="text-sm text-white/90">Shader</span></label>
          </div>
          <p class="text-xs text-white/50 mt-2">Controls the refraction calculation method</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Displacement Scale</span>
          <div class="mb-2"><span class="text-xl font-mono text-blue-300 output" data-output="displacementScale">64</span></div>
          <input type="range" min="0" max="200" step="1" value="64" name="displacementScale" />
          <p class="text-xs text-white/50 mt-2">Controls the intensity of edge distortion</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Blur Amount</span>
          <div class="mb-2"><span class="text-xl font-mono text-green-300 output" data-output="blurAmount">0.1</span></div>
          <input type="range" min="0" max="1" step="0.01" value="0.1" name="blurAmount" />
          <p class="text-xs text-white/50 mt-2">Controls backdrop blur intensity</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Saturation</span>
          <div class="mb-2"><span class="text-xl font-mono text-purple-300 output" data-output="saturation">130%</span></div>
          <input type="range" min="100" max="300" step="10" value="130" name="saturation" />
          <p class="text-xs text-white/50 mt-2">Controls color saturation of the backdrop</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Chromatic Aberration</span>
          <div class="mb-2"><span class="text-xl font-mono text-cyan-300 output" data-output="aberrationIntensity">2</span></div>
          <input type="range" min="0" max="20" step="1" value="2" name="aberrationIntensity" />
          <p class="text-xs text-white/50 mt-2">Controls RGB channel separation intensity</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Elasticity</span>
          <div class="mb-2"><span class="text-xl font-mono text-orange-300 output" data-output="elasticity">0.35</span></div>
          <input type="range" min="0" max="1" step="0.05" value="0.35" name="elasticity" />
          <p class="text-xs text-white/50 mt-2">Controls how much the glass reaches toward the cursor</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Corner Radius</span>
          <div class="mb-2"><span class="text-xl font-mono text-pink-300 output" data-output="cornerRadius">100px</span></div>
          <input type="range" min="0" max="100" step="1" value="100" name="cornerRadius" />
          <p class="text-xs text-white/50 mt-2">Controls the roundness of the glass corners</p>
        </div>
        <div>
          <span class="block text-sm font-semibold text-white/90 mb-3">Over Light</span>
          <label class="flex items-center space-x-3">
            <input type="checkbox" name="overLight" class="w-5 h-5 accent-blue-500" />
            <span class="text-sm text-white/90">Tint liquid glass dark</span>
          </label>
          <p class="text-xs text-white/50 mt-2">Makes the glass darker for better visibility on light backgrounds</p>
        </div>
      </form>
    </div>
  </div>

  <script>
    const roots = {
      user: document.getElementById("user-glass"),
      logout: document.getElementById("logout-glass"),
    };
    const forms = {
      user: document.querySelector<HTMLFormElement>('[data-controls="user"]'),
      logout: document.querySelector<HTMLFormElement>('[data-controls="logout"]'),
    };
    const panels = {
      user: document.querySelector<HTMLElement>('[data-glass-panel="user"]'),
      logout: document.querySelector<HTMLElement>('[data-glass-panel="logout"]'),
    };
    const stage = document.getElementById("scroll-container");

    function readConfig(root: HTMLElement) {
      return JSON.parse(root.dataset.lgConfig ?? "{}");
    }

    function formatOutput(name: string, value: string): string {
      if (name === "saturation") return `${value}%`;
      if (name === "cornerRadius") return `${value}px`;
      if (name === "elasticity" || name === "blurAmount") return Number(value).toFixed(2);
      return value;
    }

    function updateFromForm(key: "user" | "logout") {
      const root = roots[key];
      const form = forms[key];
      if (!root || !form) return;

      const config = readConfig(root);
      const data = new FormData(form);
      config.displacementScale = Number(data.get("displacementScale"));
      config.blurAmount = Number(data.get("blurAmount"));
      config.saturation = Number(data.get("saturation"));
      config.aberrationIntensity = Number(data.get("aberrationIntensity"));
      config.elasticity = Number(data.get("elasticity"));
      config.cornerRadius = Number(data.get("cornerRadius"));
      config.mode = String(data.get("mode"));
      config.overLight = data.get("overLight") === "on" || root.dataset.autoOverLight === "true";

      root.dataset.lgConfig = JSON.stringify(config);
      root.dataset.overLight = config.overLight ? "true" : "false";
      root.style.setProperty("--lg-radius", `${config.cornerRadius}px`);

      form.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach((input) => {
        const output = form.querySelector(`[data-output="${input.name}"]`);
        if (output) output.textContent = formatOutput(input.name, input.value);
      });

      document.dispatchEvent(new CustomEvent("liquid-glass:update", { detail: { id: root.id } }));
    }

    function setActiveTab(key: "user" | "logout") {
      document.querySelectorAll<HTMLElement>("[data-glass-panel]").forEach((panel) => {
        panel.hidden = panel.getAttribute("data-glass-panel") !== key;
      });
      document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach((button) => {
        const isActive = button.dataset.tab === key;
        button.className = isActive
          ? "tab-button flex-1 px-4 py-2 text-sm font-medium rounded-md bg-blue-500 text-white shadow-lg"
          : "tab-button flex-1 px-4 py-2 text-sm font-medium rounded-md text-white/70 hover:text-white hover:bg-white/10";
      });
      Object.entries(forms).forEach(([k, form]) => {
        if (form) form.hidden = k !== key;
      });
    }

    function updateAutoOverLight() {
      const scroll = stage?.scrollTop ?? 0;
      const bright = scroll > 230 && scroll < 500;
      Object.entries(roots).forEach(([key, root]) => {
        if (!(root instanceof HTMLElement)) return;
        root.dataset.autoOverLight = bright ? "true" : "false";
        updateFromForm(key as "user" | "logout");
      });
    }

    function updateGlassCenter() {
      const panel = document.getElementById("scroll-container");
      if (!panel) return;
      const rect = panel.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      document.documentElement.style.setProperty("--lg-panel-x", center + "px");
    }
    window.addEventListener("resize", updateGlassCenter);
    updateGlassCenter();

    forms.user?.addEventListener("input", () => updateFromForm("user"));
    forms.logout?.addEventListener("input", () => updateFromForm("logout"));
    document.querySelectorAll("[data-tab]").forEach((button) => {
      button.addEventListener("click", () => {
        const tab = (button as HTMLButtonElement).dataset.tab;
        setActiveTab(tab === "logout" ? "logout" : "user");
      });
    });
    stage?.addEventListener("scroll", () => requestAnimationFrame(updateAutoOverLight));

    updateFromForm("user");
    updateFromForm("logout");
  </script>
</body>
</html>
